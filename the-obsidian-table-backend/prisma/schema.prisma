generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Restaurant {
  id   Int    @id @default(autoincrement())
  slug String @unique

  name        String
  description String
  type        String // cuisine, e.g. "French", "Japanese", "Fast Food"

  totalScore   Float
  scoreFood    Float
  scoreService Float
  scoreAtmo    Float
  scorePrice   Float

  country String
  city    String

  tags Tag[]

  images        String[]
  verdict       String
  address       String
  googleMapsUrl String
  priceLevel    Int // 1-4, rendered as $ / $$ / $$$ / $$$$
  priceNote     String

  reviewFoodText    String
  reviewAtmoText    String
  reviewServiceText String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Tag {
  id   Int    @id @default(autoincrement())
  name String @unique

  restaurants Restaurant[]
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Restaurant {
  id        Int    @id @default(autoincrement())
  slug      String @unique
  name      String
  type      String
  tagline   String
  score     Float
  verdict   String
  images    String[]

  qualityScore    Float
  atmosphereScore Float
  priceScore      Float
  serviceScore    Float

  address     String
  city        String
  priceLevel  String
  priceNote   String
  hours       String
  hoursDetail String

  reviewQualityTitle     String
  reviewQualityText      String
  reviewAtmosphereTitle  String
  reviewAtmosphereText   String
  reviewServiceTitle     String
  reviewServiceText      String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
